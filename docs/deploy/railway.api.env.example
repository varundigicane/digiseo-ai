# Copy into Railway → api service → Variables (then edit domains)

APP_ENV=production
APP_NAME=DigiSEO AI
SECRET_KEY=REPLACE_WITH_LONG_RANDOM_SECRET
MOCK_LLM=true
MOCK_CRAWL=true

# After web domain exists:
WEB_URL=https://REPLACE-web.up.railway.app
API_URL=https://REPLACE-api.up.railway.app
CORS_ORIGINS=https://REPLACE-web.up.railway.app

# From Railway Postgres plugin (preferred as a reference variable):
# DATABASE_URL=${{Postgres.DATABASE_URL}}

# Optional
# OPENAI_API_KEY=
# ANTHROPIC_API_KEY=
# REDIS_URL=${{Redis.REDIS_URL}}
# QDRANT_URL=
