{
  "name": "digiseo-ai",
  "version": "0.1.0",
  "private": true,
  "description": "DigiSEO AI — Enterprise Multi-Agent Marketing Platform",
  "workspaces": [
    "apps/web",
    "packages/*"
  ],
  "scripts": {
    "dev:web": "npm run dev --workspace=apps/web",
    "build": "npm run build --workspace=apps/web",
    "start": "npm run start --workspace=apps/web",
    "build:web": "npm run build --workspace=apps/web",
    "lint": "npm run lint --workspace=apps/web",
    "test:api": "cd apps/api && .venv/Scripts/python.exe -m pytest tests -q",
    "test:e2e": "npm run test:e2e --workspace=apps/web",
    "docker:up": "docker compose -f infra/docker/docker-compose.yml up -d",
    "docker:down": "docker compose -f infra/docker/docker-compose.yml down"
  },
  "engines": {
    "node": ">=20"
  }
}
