# App
APP_NAME=DigiSEO AI
APP_ENV=development
API_URL=http://localhost:8000
WEB_URL=http://localhost:3000
SECRET_KEY=change-me-in-production-use-long-random-string
JWT_ALGORITHM=HS256
JWT_EXPIRE_MINUTES=10080

# Database
DATABASE_URL=sqlite+aiosqlite:///./digiseo.db
DATABASE_URL_SYNC=sqlite:///./digiseo.db
# Production Postgres:
# DATABASE_URL=postgresql+asyncpg://digiseo:digiseo@localhost:5432/digiseo
# DATABASE_URL_SYNC=postgresql://digiseo:digiseo@localhost:5432/digiseo

# Redis
REDIS_URL=redis://localhost:6379/0

# Qdrant
QDRANT_URL=http://localhost:6333
QDRANT_COLLECTION=digiseo_chunks

# Stripe
STRIPE_SECRET_KEY=sk_test_xxx
STRIPE_WEBHOOK_SECRET=whsec_xxx
STRIPE_PRICE_STARTER=price_starter
STRIPE_PRICE_PROFESSIONAL=price_professional
STRIPE_PRICE_BUSINESS=price_business
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_xxx

# Auth (dev JWT; swap to Clerk in production)
NEXT_PUBLIC_API_URL=http://localhost:8000
NEXT_PUBLIC_APP_URL=http://localhost:3000

# LLMs (optional — mock mode if unset)
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
GOOGLE_AI_API_KEY=

# Google OAuth (GSC / GA4)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=http://localhost:8000/api/v1/integrations/google/callback

# Object storage (optional)
S3_ENDPOINT=
S3_ACCESS_KEY=
S3_SECRET_KEY=
S3_BUCKET=digiseo

# Feature flags
MOCK_LLM=true
MOCK_CRAWL=false

# Railway / production extras
# PORT is injected by Railway automatically
# CORS_ORIGINS=https://your-web.up.railway.app
# DATABASE_SSL=true   # auto-enabled for *.rlwy.net hosts
# Link Postgres: set DATABASE_URL from Railway plugin (${{Postgres.DATABASE_URL}})
